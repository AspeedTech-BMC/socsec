{
    "name": "AST2700A2_ROM_patch_v5",
    "version": "2700A2",
    "rom_region": {
	"file_name": "all_patches.bin",
        "w_offset": "0x0"
    },
    "config_region": {
	// OTPCFG0[5]
        // Enable static write protection of OTPROM region
        // Once it's enabled, no one can prog the OTPROM region anymore.
        "wr_protect_rom": true,
	// OTPCFG11[7]
        // Enable Write protect for OTP region user 3
        "wr_protect_otp_usr3": true,
	// OTPCFG24[10: 1]
        // OTP patch code offset
        // The OTP patch code location in OTPROM Region.
        "OTP_Patch_Code_location_3": "0x0",
        // OTPCFG24[0]
        // Enable otp patch 3
        // 0: otp rom patch 3 is invalid
        // 1: otp rom patch 3 is valid
        "otp_patch_vld_3": true,
        // OTPCFG25[9: 0]
        // OTP Patch 3 code size (unit: word)
        // The Boot ROM can execute OTP patch codes in OTPROM region. The OTP patch code size is
        // limited of 16Kbit.
        "OTP_Patch_Size_3": "0x220",
	// OTPCFG26[10: 1]
        // OTP patch code offset
        // The OTP patch code location in OTPROM Region.
        "OTP_Patch_Code_location_4": "0x220",
        // OTPCFG26[0]
        // Enable otp patch 4
        // 0: otp rom patch 4 is invalid
        // 1: otp rom patch 4 is valid
        "otp_patch_vld_4": true,
        // OTPCFG27[9: 0]
        // OTP Patch 4 code size (unit: word)
        // The Boot ROM can execute OTP patch codes in OTPROM region. The OTP patch code size is
        // limited of 16Kbit.
        "OTP_Patch_Size_4": "0xb0",
        // OTPCFG28[10: 1]
        // OTP patch code offset
        // The OTP patch code location in OTPROM Region.
        "OTP_Patch_Code_location_5": "0x2d0",
        // OTPCFG28[0]
        // Enable otp patch 5
        // 0: otp rom patch 5 is invalid
        // 1: otp rom patch 5 is valid
        "otp_patch_vld_5": true,
        // OTPCFG29[9: 0]
        // OTP Patch 5 code size (unit: word)
        // The Boot ROM can execute OTP patch codes in OTPROM region. The OTP patch code size is
        // limited of 16Kbit.
        "OTP_Patch_Size_5": "0x40"
    },
    "user_region": {
        // OTPUSR 0x440 - 14336 bits
        // rom_patch_user.bin: 2732 bytes (21856 bits)
	"ROM_patch": ""
    }
}
