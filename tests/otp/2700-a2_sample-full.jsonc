    "caliptra_region": {
        // OTPCAL0
        // Caliptra fuse: LMS VERIFY
        // Verify Caliptra firmware images with both ECDSA and LMS
        "Enable_LMS_verify": false,
        // OTPCAL1
        // Caliptra fuse: ANTI-ROLLBACK DISABLE
        // Disable anti-rollback support from Caliptra
        "Anti-rollback_disable": false,
        // OTPCAL2
        // Caliptra fuse: FIELD ENTROPY
        // Owner secret of hedge against UDS disclosure in the supply chain
        "Field_Entropy": "",
        // OTPCAL18
        // Caliptra fuse: KEY MANIFEST PK HASH
        // Manufacture/Vendor key hash
        "Manufacture_Key_Hash": "",
        // OTPCAL42
        // Caliptra fuse: IDEVID CERT IDEVID ATTR
        // The information for generating IDEVID CSR
        // DW 0: X509 key ID algorithm
        // 0: SHA1
        // 1: SHA256
        // 2: SHA384
        // 3: Fuse → already programmed DW 1/2/3/4/5, not runtime gen
        // DW 1/2/3/4/5: Subject Key ID
        // DW 6: ueid_type (0x1: random)
        // DW 7/8/9/10: Unique endpoint ID (Manufacture Serial number)
        "IDEVID_Cert_attr": "",
        // OTPCAL90
        // Caliptra fuse: IDEVID MANUF HSM IDENTIFIER
        // Vendor IDevID provisioner CA identifiers
        "IDEVID_manuf_HSM_identifier": "",
        // OTPCAL98
        // of-be-signed (TBS) payload.
        // The TBS is the certificate template already patched with the IDevID public key, Subject
        // Key Identifier, serial number, and any extensions that are unique of the device that the
        // vendor may have included.
        // Maximum size is 916 bytes according of mailbox command
        "IDEVID_TBS": "",
        // OTPCAL610
        // IDEVID Certificate Signature R & S
        "IDEVID_Cert_Signature": ""
    }
}
