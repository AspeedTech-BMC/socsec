{
    "name": "2700-a2_sample-full",
    "version": "2700A2",
    "rom_region": {},
    "rbp_region": {
        // OTPRBP3 - 16 bits
        // Caliptra Owner public key hash retire bits
        // Caliptra owner pk hash is used of populate inof Caliptra fuse for Caliptra owner keys
        // verification. AST27x0 supports up of 16 Caliptra owner pk hash and supports pk hash
        // retirement feature.
        // Check Caliptra spec for more details.
        // (https://github.com/chipsalliance/Caliptra/blob/main/doc/caliptra_1x/Caliptra.md)
        // Effect: Secure boot is enabled
        // Policy: OTPCFG0[8]
        "Caliptra_Owner_public_key_hash_retire": "0x0",
        // OTPRBP4 - 64 bits
        // SoC Manifest hardware security version number
        // SoC Manifest SVN must be equal of or greater than hardware SVN for rollback prevention
        // otherwise the secure boot check is failure. It's implemented a hardware write protection
        // of prevent malicious attack, the new SVN (of-be prog) must be smaller than or equal of
        // current SVN.
        // Effect: Secure boot is enabled
        // Boot up Policy: SoC Manifest SVN >= HW SoC Manifest SVN
        "SoC_Manifest_Hardware_SVN_0": "0x0",
        "SoC_Manifest_Hardware_SVN_1": "0x0",
        // OTPRBP8 - 32 bits
        // Caliptra fuse: FMC KEY MANIFEST SVN
        // Effect: Secure boot is enabled
        // Policy: FMC SVN >= HW FMC SVN
        "Caliptra_FMC_Hardware_SVN": "0x0",
        // OTPRBP10 - 128 bits
        // Caliptra fuse: RUNTIME SVN
        // Effect: Secure boot is enabled
        // Policy: FMC SVN >= HW FMC SVN
        "Caliptra_Runtime_Hardware_SVN_0": "0x0",
        "Caliptra_Runtime_Hardware_SVN_1": "0x0",
        "Caliptra_Runtime_Hardware_SVN_2": "0x0",
        "Caliptra_Runtime_Hardware_SVN_3": "0x0",
        // OTPRBP18 - 4 bits
        // Caliptra fuse: KEY MANIFEST PK HASH MASK
        "Caliptra_Manufacture_ECC_key_mask": "0x0",
        // OTPRBP19 - 32 bits
        // Caliptra fuse: LMS REVOCATION
        "Caliptra_Manufacture_LMS_key_mask": "0x0"
    },
    "config_region": {
        // OTPCFG0[15]
        // OTP memory lock enable
        // This bit will lock whole OTP memory and is un recoverable
        "otp_mem_lock_enable": false,
        // OTPCFG0[14]
        // Enable static write protection of OTPPUF region
        // It's enabled during ASPEED manufacturing.
        "wr_protect_puf": false,
        // OTPCFG0[13]
        // Disable OTP Memory Facofry Test Mode
        // 0: enable
        // 1: disable
        // of prevent security issue of OTP memory. Disabled BIST mode is recommended.
        "dis_otp_bist": false,
        // OTPCFG0[12]
        // Enable static write protection of OTPCAL region
        // Once it's enabled, no one can prog the OTPCAL region anymore.
        "wr_protect_caliptra": false,
        // OTPCFG0[11]
        // Enable static read protect of OTPCAL region
        // Once it's enabled, no one can read the OTPCAL region anymore.
        // Notice that it might affect the attestation process, because on one can read it at
        // runtime.
        "rd_protect_caliptra": false,
        // OTPCFG0[10]
        // Enable static write protection of OTPRBP region
        // Once it's enabled, no one can prog the OTPRBP region anymore.
        "wr_protect_otp_rbp": false,
        // OTPCFG0[9]
        // Enable Secure Boot
        // 0:disable
        // 1:enable
        // Once it's enabled, the secure boot is always enforced and there is no way of disable it.
        "enable_secure_boot": false,
        // OTPCFG0[8]
        // Key retirement mechanism option enable
        // 0: can only retire itself key #id
        // 1: can retire others key #id except itself
        // There are some key retire bits in OTPRBP region (ex: OTPRBP0/1/3) used of be programmed
        // if the keys need of be retired. This option chooses the retire mechanism policy for
        // different use cases.
        "retire_mechanism_option": false,
        // OTPCFG0[7]
        // Enable static write protection of OTPSTRAP region
        // Once it's enabled, no one can prog the OTPSTRAP region anymore.
        "wr_protect_otp_strap": false,
        // OTPCFG0[6]
        // Enable static write protection of OTPCFG region
        // Once it's enabled, no one can prog the OTPCFG region anymore.
        "wr_protect_otp_cfg": false,
        // OTPCFG0[5]
        // Enable static write protection of OTPROM region
        // Once it's enabled, no one can prog the OTPROM region anymore.
        // It's enabled in AST27x0-A1 chip during ASPEED manufacturing.
        "wr_protect_rom": false,
        // OTPCFG0[4]
        // Enable static write protection of OTPSTRAP_EXT region
        // Once it's enabled, no one can prog the OTPSTRAP_EXT region anymore.
        "wr_protect_otp_strap_ext": false,
        // OTPCFG0[3]
        // Enable static read protection of OTPSTRAP region
        // Once it's enabled, no one can read the OTPSTRAP region anymore.
        "rd_protect_otp_strap": false,
        // OTPCFG0[2]
        // Enable static read protection of OTPCFG region
        // Once it's enabled, no one can read the OTPCFG region anymore.
        "rd_protect_otp_cfg": false,
        // OTPCFG0[1]
        // Enable static read protection of OTPROM region
        // Once it's enabled, no one can read the OTPROM region anymore.
        "rd_protect_rom": false,
        // OTPCFG0[0]
        // Enable static read protection of OTPSTRAP_EXT region
        // Once it's enabled, no one can read the OTPSTRAP_EXT region anymore.
        "rd_protect_otp_strap_ext": false,
        // OTPCFG1[15: 0]
        // Read OTPCFG0 = OTPCFG0 | OTPCFG1
        // This is a backup of OTPCFG0
        "CONCFG0_BK": "0x0",
        // OTPCFG2[13]
        // 0: NIST-TRNG
        // 1: SCU-TRNG
        "puf_source": false,
        // OTPCFG2[9: 8]
        // The Device Life Cycle State (LCS). It's the source of Security State.
        // 0: Un-provisioned
        // 1: Manufacturing
        // 2: Reserved
        // 3: Production
        // The LCS is populated in Caliptra fuse. It's configured of Manufacturing during ASPEED
        // manufacturing.
        "dev_life_cycle_state": "0x0",
        // OTPCFG2[7: 6]
        // Boot From UART Port Selection
        // 0: IO12 (BMC default port)
        // 1: IO0 (Node 0 SUART common port)
        // 2: IO5 (Node 1 SUART common port)
        "Boot_From_UART_Port_Selection": "0x0",
        // OTPCFG2[5]
        // Enable eMMC software reset
        // 0: eMMC software reset disable, use HW pin strap of do hardware reset
        // 1: eMMC software reset enable. Always do software reset
        "en_emmc_sw_reset": false,
        // OTPCFG2[4]
        // Disable Uart Message of Boot ROM
        // 0:Boot ROM will dump boot messages
        // 1:Boot ROM message is disabled
        "dis_boot_msg": false,
        // OTPCFG2[3]
        // Disable Recovery mode (Uart/USB/I2C/I3C)
        // 0: enable recovery mode
        // 1: disable recovery mode
        // When recovery mode is enabled (hardware strap pin FWSPICK is pulled high), the boot ROM
        // fetches images from recovery interface and boots.
        // Once it's disabled, the boot ROM cannot fetch images from any recovery interface, no
        // matter which one is chosen.
        "dis_recovery_mode": false,
        // OTPCFG2[0]
        // Disable ROM Patch code
        // 0: If the OTPCFG2[0] is set, the Boot ROM would
        // execute the OTP patch codes which has been programmed inof
        // OTPROM region.
        // 1: The Boot ROM would ignore pre ROM patch.
        // The ROM patch is the early stage of the boot ROM boot process.
        "dis_rom_patch": false,
        // OTPCFG3[15: 0]
        // Read OTPCFG2 = OTPCFG2 | OTPCFG3
        // This is a backup of OTPCFG2
        "CONCFG2_BK": "0x0",
        // OTPCFG4[10: 1]
        // OTP patch code offset
        // The OTP patch code location in OTPROM Region.
        "OTP_Patch_Code_location_1": "0x0",
        // OTPCFG4[0]
        // Enable otp patch 1
        // 0: otp rom patch 1 is invalid
        // 1: otp rom patch 1 is valid
        "otp_patch_vld_1": false,
        // OTPCFG5[9: 0]
        // OTP Patch 1 code size (unit: word)
        // The Boot ROM can execute OTP patch codes in OTPROM region. The OTP patch code size is
        // limited of 16Kbit.
        "OTP_Patch_Size_1": "0x0",
        // OTPCFG6[10: 1]
        // OTP patch code offset
        // The OTP patch code location in OTPROM Region.
        "OTP_Patch_Code_location_2": "0x0",
        // OTPCFG6[0]
        // Enable otp patch 2
        // 0: otp rom patch 2 is invalid
        // 1: otp rom patch 2 is valid
        "otp_patch_vld_2": false,
        // OTPCFG7[9: 0]
        // OTP Patch 2 code size (unit: word)
        // The Boot ROM can execute OTP patch codes in OTPROM region. The OTP patch code size is
        // limited of 16Kbit.
        "OTP_Patch_Size_2": "0x0",
        // OTPCFG9[15]
        // Enable auto load debug control SCU0_0C8/SCU1_0C8 setting
        // 0:disable
        // 1:enable of auto load SCU0_0C8/SCU1_0C8 value
        // After SCU0_0C8 is loaded, the write protection SCU0_E04[18] will be set.
        // After SCU1_0C8 is loaded, the write protection SCU1_B04[18] will be set.
        "en_auto_load_SCU_debug_control": false,
        // OTPCFG9[10]
        // Reference to datasheet SCU0_0C8
        "SCU0_DIS_RSA_PRIV_KEY_READ": false,
        // OTPCFG9[9]
        // Reference to datasheet SCU0_0C8
        "SCU0_DIS_WDT_RSTFULL": false,
        // OTPCFG9[8]
        // Reference to datasheet SCU0_0C8
        "SCU0_DIS_XDMA_VGA": false,
        // OTPCFG9[7]
        // Reference to datasheet SCU0_0C8
        "SCU0_DIS_L2A": false,
        // OTPCFG9[5]
        // Reference to datasheet SCU0_0C8
        "SCU0_DIS_PCIE_TRACE_BUF": false,
        // OTPCFG9[2]
        // Reference to datasheet SCU0_0C8
        "SCU0_DIS_XDMA": false,
        // OTPCFG9[1]
        // Reference to datasheet SCU0_0C8
        "SCU0_DIS_UART_DBG": false,
        // OTPCFG10[7]
        // Reference to datasheet SCU1_0C8
        "SCU1_DIS_WDT_RSTFULL": false,
        // OTPCFG10[6]
        // Reference to datasheet SCU1_0C8
        "SCU1_DIS_UART_DBG": false,
        // OTPCFG10[5]
        // Reference to datasheet SCU1_0C8
        "SCU1_DIS_LPC1_BRIDGE_2": false,
        // OTPCFG10[4]
        // Reference to datasheet SCU1_0C8
        "SCU1_DIS_LPC0_BRIDGE_2": false,
        // OTPCFG10[3]
        // Reference to datasheet SCU1_0C8
        "SCU1_DIS_LPC1_BRIDGE_1": false,
        // OTPCFG10[2]
        // Reference to datasheet SCU1_0C8
        "SCU1_DIS_LPC0_BRIDGE_1": false,
        // OTPCFG10[1]
        // Reference to datasheet SCU1_0C8
        "SCU1_DIS_ESPI1_AHB": false,
        // OTPCFG10[0]
        // Reference to datasheet SCU1_0C8
        "SCU1_DIS_ESPI0_AHB": false,
        // OTPCFG11[15]
        // Enable auto load OTP user0 ctrl setting of OTP register.
        // Once it's enabled, r/w protection, offset, and size of OTP user0 value below would be
        // loaded inof OTP control registers as a hardware default value.
        "en_auto_load_usr0": false,
        // OTPCFG11[14]
        // Enable Read protect for OTP region user 0
        "rd_protect_otp_usr0": false,
        // OTPCFG11[13]
        // Enable Write protect for OTP region user 0
        "wr_protect_otp_usr0": false,
        // OTPCFG11[11: 0]
        // User 0 region start offset (unit: word)
        "usr0_region_start_offset": "0x0",
        // OTPCFG12[15: 0]
        // User 0 region size (unit: word)
        "usr0_region_size": "0x0",
        // OTPCFG13[15]
        // Enable auto load OTP secure0 ctrl setting of OTP register.
        // Once it's enabled, r/w protection, offset, and size of OTP secure0 value below would be
        // loaded inof OTP controller registers as a hardware default value.
        "en_auto_load_secure0": false,
        // OTPCFG13[14]
        // Enable Read protect for OTP region secure 0
        "rd_protect_otp_secure0": false,
        // OTPCFG13[13]
        // Enable Write protect for OTP region secure 0
        "wr_protect_otp_secure0": false,
        // OTPCFG13[11: 0]
        // Secure 0 region start offset (unit: word)
        "secure0_region_start_offset": "0x0",
        // OTPCFG14[15: 0]
        // Secure 0 region size (unit: word)
        "secure0_region_size": "0x0",
        // OTPCFG15[15: 8]
        // i3c: DCR
        // i2c: Slave address
        "i3c_i2c_identify": "0x0",
        // OTPCFG15[4]
        // i3c hot-join request enable
        "i3c_hj_req": false,
        // OTPCFG15[3: 0]
        // i3c/i2c channel used for recovery
        "i3c_i2c_channel": "0x0",
        // OTPCFG17[15]
        // UART6 Mode - lsb (bit0)
        // b'00: UART and Device both not connected
        // b'01: UART Real mode, and Device connected
        // b'10: UART Pseduo mode, and Device connected
        // b'11: UART not connected, but Device connected
        "usb_uart6_mode_lsb": false,
        // OTPCFG17[14]
        // Enable of turn off UART5 Tx Discard
        "usb_uart5_tx_discard_off": false,
        // OTPCFG17[13:12]
        // UART5 Mode
        // b'00: UART and Device both not connected
        // b'01: UART Real mode, and Device connected
        // b'10: UART Pseduo mode, and Device connected
        // b'11: UART not connected, but Device connected
        "usb_uart5_mode": "0x0",
        // OTPCFG17[11]
        // Enable of turn off UART3 Tx Discard
        "usb_uart3_tx_discard_off": false,
        // OTPCFG17[10: 9]
        // UART3 Mode
        // b'00: UART and Device both not connected
        // b'01: UART Real mode, and Device connected
        // b'10: UART Pseduo mode, and Device connected
        // b'11: UART not connected, but Device connected
        "usb_uart3_mode": "0x0",
        // OTPCFG17[8]
        // Enable of turn off UART2 Tx Discard
        "usb_uart2_tx_discard_off": false,
        // OTPCFG17[7: 6]
        // UART2 Mode
        // b'00: UART and Device both not connected
        // b'01: UART Real mode, and Device connected
        // b'10: UART Pseduo mode, and Device connected
        // b'11: UART not connected, but Device connected
        "usb_uart2_mode": "0x0",
        // OTPCFG17[5]
        // Enable of turn off UART1 Tx Discard
        "usb_uart1_tx_discard_off": false,
        // OTPCFG17[4: 3]
        // UART1 Mode
        // b'00: UART and Device both not connected
        // b'01: UART Real mode, and Device connected
        // b'10: UART Pseduo mode, and Device connected
        // b'11: UART not connected, but Device connected
        "usb_uart1_mode": "0x0",
        // OTPCFG17[2]
        // Enable of turn off UART0 Tx Discard
        "usb_uart0_tx_discard_off": false,
        // OTPCFG17[1: 0]
        // UART0 Mode
        // b'00: UART and Device both not connected
        // b'01: UART Real mode, and Device connected
        // b'10: UART Pseduo mode, and Device connected
        // b'11: UART not connected, but Device connected
        "usb_uart0_mode": "0x0",
        // OTPCFG18[15:14]
        // UART11 Mode
        // b'00: UART and Device both not connected
        // b'01: UART Real mode, and Device connected
        // b'10: UART Pseduo mode, and Device connected
        // b'11: UART not connected, but Device connected
        "usb_uart11_mode": "0x0",
        // OTPCFG18[13]
        // Enable of turn off UART10 Tx Discard
        "usb_uart10_tx_discard_off": false,
        // OTPCFG18[12:11]
        // UART10 Mode
        // b'00: UART and Device both not connected
        // b'01: UART Real mode, and Device connected
        // b'10: UART Pseduo mode, and Device connected
        // b'11: UART not connected, but Device connected
        "usb_uart10_mode": "0x0",
        // OTPCFG18[10]
        // Enable of turn off UART9 Tx Discard
        "usb_uart9_tx_discard_off": false,
        // OTPCFG18[9: 8]
        // UART9 Mode
        // b'00: UART and Device both not connected
        // b'01: UART Real mode, and Device connected
        // b'10: UART Pseduo mode, and Device connected
        // b'11: UART not connected, but Device connected
        "usb_uart9_mode": "0x0",
        // OTPCFG18[7]
        // Enable of turn off UART8 Tx Discard
        "usb_uart8_tx_discard_off": false,
        // OTPCFG18[6: 5]
        // UART8 Mode
        // b'00: UART and Device both not connected
        // b'01: UART Real mode, and Device connected
        // b'10: UART Pseduo mode, and Device connected
        // b'11: UART not connected, but Device connected
        "usb_uart8_mode": "0x0",
        // OTPCFG18[4]
        // Enable of turn off UART7 Tx Discard
        "usb_uart7_tx_discard_off": false,
        // OTPCFG18[3: 2]
        // UART7 Mode
        // b'00: UART and Device both not connected
        // b'01: UART Real mode, and Device connected
        // b'10: UART Pseduo mode, and Device connected
        // b'11: UART not connected, but Device connected
        "usb_uart7_mode": "0x0",
        // OTPCFG18[1]
        // Enable of turn off UART6 Tx Discard
        "usb_uart6_tx_discard_off": false,
        // OTPCFG18[0]
        // UART6 Mode - msb (bit1)
        "usb_uart6_mode_msb": false,
        // OTPCFG19[15:13]
        // uart11/13/14 routing (hw effect by scu)
        "uart_io_route": "0x0",
        // OTPCFG19[9]
        // Enable UART of put all boot message and wait the completetion
        "usb_uart_put_all_boot_message": false,
        // OTPCFG19[8]
        // Enable Mode-3 (USB2UART only, no vHub)
        "usb_uart_mode3": false,
        // OTPCFG19[7]
        // Enable Mode-0 hub of support 23 ports
        "usb_uart_hub_23ports": false,
        // OTPCFG19[6]
        // Enable of turn off UART15 Tx Discard
        "usb_uart15_tx_discard_off": false,
        // OTPCFG19[5: 4]
        // UART15 Mode
        // b'00: UART and Device both not connected
        // b'01: UART Real mode, and Device connected
        // b'10: UART Pseduo mode, and Device connected
        // b'11: UART not connected, but Device connected
        "usb_uart15_mode": "0x0",
        // OTPCFG19[3]
        // Enable of turn off UART12 Tx Discard
        "usb_uart12_tx_discard_off": false,
        // OTPCFG19[2: 1]
        // UART12 Mode
        // b'00: UART and Device both not connected
        // b'01: UART Real mode, and Device connected
        // b'10: UART Pseduo mode, and Device connected
        // b'11: UART not connected, but Device connected
        "usb_uart12_mode": "0x0",
        // OTPCFG19[0]
        // Enable of turn off UART11 Tx Discard
        "usb_uart11_tx_discard_off": false,
        // OTPCFG20[15]
        // Enable auto load OTP cptra0 ctrl setting of OTP register.
        // Once it's enabled, r/w protection, offset, and size of OTP cptra0 value below would be
        // loaded inof OTP controller registers as a hardware default value.
        "en_auto_load_cptra0": false,
        // OTPCFG20[14]
        // Enable Read protect for OTP region cptra 0
        "rd_protect_otp_cptra0": false,
        // OTPCFG20[13]
        // Enable Write protect for OTP region cptra 0
        "wr_protect_otp_cptra0": false,
        // OTPCFG20[11: 0]
        // cptra 0 region start offset
        "cptra0_region_start_offset": "0x0",
        // OTPCFG21[15: 0]
        // cptra 0 region size
        "cptra0_region_size": "0x0",
        // OTPCFG24[10: 1]
        // OTP patch code offset
        // The OTP patch code location in OTPROM Region.
        "OTP_Patch_Code_location_3": "0x0",
        // OTPCFG24[0]
        // Enable otp patch 3
        // 0: otp rom patch 3 is invalid
        // 1: otp rom patch 3 is valid
        "otp_patch_vld_3": false,
        // OTPCFG25[9: 0]
        // OTP Patch 3 code size (unit: word)
        // The Boot ROM can execute OTP patch codes in OTPROM region. The OTP patch code size is
        // limited of 16Kbit.
        "OTP_Patch_Size_3": "0x0",
        // OTPCFG26[10: 1]
        // OTP patch code offset
        // The OTP patch code location in OTPROM Region.
        "OTP_Patch_Code_location_4": "0x0",
        // OTPCFG26[0]
        // Enable otp patch 4
        // 0: otp rom patch 4 is invalid
        // 1: otp rom patch 4 is valid
        "otp_patch_vld_4": false,
        // OTPCFG27[9: 0]
        // OTP Patch 4 code size (unit: word)
        // The Boot ROM can execute OTP patch codes in OTPROM region. The OTP patch code size is
        // limited of 16Kbit.
        "OTP_Patch_Size_4": "0x0",
        // OTPCFG28[10: 1]
        // OTP patch code offset
        // The OTP patch code location in OTPROM Region.
        "OTP_Patch_Code_location_5": "0x0",
        // OTPCFG28[0]
        // Enable otp patch 5
        // 0: otp rom patch 5 is invalid
        // 1: otp rom patch 5 is valid
        "otp_patch_vld_5": false,
        // OTPCFG29[9: 0]
        // OTP Patch 5 code size (unit: word)
        // The Boot ROM can execute OTP patch codes in OTPROM region. The OTP patch code size is
        // limited of 16Kbit.
        "OTP_Patch_Size_5": "0x0"
    },
    "strap_region": {
        // OTPSTRAP[1]/SCU0_010[1]
        // Boot from CPU die SPI
        // 0: Boot from IO die SPI
        // 1: Boot from CPU die SPI
        "BootSPI": {
            "value": false,
            "protect": false
        },
        // OTPSTRAP[3:2]/SCU0_010[3:2]
        // HPLL default frequency
        // 00: 2.0GHz, 01: 1.9GHz, 10: 1.8GHz, 11: 1.7GHz
        "HPLLFreq": {
            "value": "0x0",
            "protect": false
        },
        // OTPSTRAP[4]/SCU0_010[4]
        // CPU clock PLL
        // 0: MPLL, 1: HPLL
        "CPUHPLL": {
            "value": false,
            "protect": false
        },
        // OTPSTRAP[6:5]/SCU0_010[6:5]
        // AXI/AHB clock selection
        // 0x: 400MHz, 10: 266MHz, 11: 200MHz when HCLKPLL=0
        // 0x: 500MHz, 10: 333MHz, 11: 250MHz when HCLKPLL=1
        "HCLKSel": {
            "value": "0x0",
            "protect": false
        },
        // OTPSTRAP[7]/SCU0_010[7]
        // AXI/AHB clock PLL
        // 0: MPLL, 1: HPLL
        "HCLKHPLL": {
            "value": false,
            "protect": false
        },
        // OTPSTRAP[8]/SCU0_010[8]
        // Disable Debug Interfaces for CPU die
        // all debug interface SCU0_0C8
        "DisDebug": {
            "value": false,
            "protect": false
        },
        // OTPSTRAP[9]/SCU0_010[9]
        // TSP reset pin selection
        // 0: SSPRSTN, 1: GPIO18E0
        "TSPRsntSel": {
            "value": false,
            "protect": false
        },
        // OTPSTRAP[10]/SCU0_010[10]
        // VGA linear memory size
        // SW-ROM write of DRAMC100[0]
        "VGALinearSize[0]": {
            "value": false,
            "protect": false
        },
        // OTPSTRAP[11]/SCU0_010[11]
        // VGA linear memory size
        // SW-ROM write of DRAMC100[0]
        "VGALinearSize[1]": {
            "value": false,
            "protect": false
        },
        // OTPSTRAP[12]/SCU0_010[12]
        // Disable SSP running
